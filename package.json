{
  "name": "spit",
  "version": "1.0.0",
  "description": "Simple Node.js Express project with PostgreSQL integration and CRUD API",
  "main": "src/app.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "migrate": "sequelize-cli db:migrate --config src/config/database.js --migrations-path src/migrations --models-path src/models",
    "migrate:undo": "sequelize-cli db:migrate:undo:all --config src/config/database.js --migrations-path src/migrations --models-path src/models",
    "seed": "sequelize-cli db:seed:all --config src/config/database.js --seeders-path src/seeders",
    "seed:undo": "sequelize-cli db:seed:undo:all --config src/config/database.js --seeders-path src/seeders",
    "db:reset": "npm run migrate:undo && npm run migrate && npm run seed",
    "db:fresh": "node src/scripts/dropTables.js && npm run migrate && npm run seed"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "body-parser": "^1.20.2",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.4",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^9.0.1",
    "pg": "^8.11.1",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8",
    "sequelize-cli": "^6.6.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
